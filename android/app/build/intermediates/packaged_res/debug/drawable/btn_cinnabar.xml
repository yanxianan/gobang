<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#8B1E1E"
                android:endColor="#5C1010"
                android:angle="270" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#3A0A0A" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#A89070" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#B23A48"
                android:endColor="#8B1E1E"
                android:angle="270" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#4A2C0F" />
        </shape>
    </item>
</selector>
