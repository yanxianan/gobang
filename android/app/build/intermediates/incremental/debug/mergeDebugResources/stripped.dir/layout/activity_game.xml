<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_rice_paper"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ink_brown"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:text="‹ 返回"
            android:textColor="@color/rice_paper"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_room_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/gold"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="房间号: AB12CD" />
    </LinearLayout>

    <!-- 双方信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:layout_margin="8dp"
        android:orientation="horizontal"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@color/stone_black" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_black_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="小明" />

                <TextView
                    android:id="@+id/tv_black_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cinnabar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="00:30" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:background="@color/stone_white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_white_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="小红" />

                <TextView
                    android:id="@+id/tv_white_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cinnabar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="00:30" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 状态条 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="6dp"
        android:textColor="@color/cinnabar"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="轮到你走" />

    <!-- 棋盘 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="6dp">

        <com.gomoku.app.ui.game.BoardView
            android:id="@+id/board_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="4dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_undo"
            style="@style/GomokuButton.Outline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/btn_undo" />

        <Button
            android:id="@+id/btn_draw"
            style="@style/GomokuButton.Outline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:text="@string/btn_draw" />

        <Button
            android:id="@+id/btn_resign"
            style="@style/GomokuButton.Outline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/btn_resign" />
    </LinearLayout>

    <!-- 聊天列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_chat"
        android:padding="6dp"
        android:scrollbars="vertical" />

    <!-- 表情快捷栏 -->
    <LinearLayout
        android:id="@+id/emoji_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="😀"
            android:textSize="24sp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="😂"
            android:textSize="24sp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="😡"
            android:textSize="24sp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="😱"
            android:textSize="24sp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="👍"
            android:textSize="24sp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="👎"
            android:textSize="24sp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="🙏"
            android:textSize="24sp" />

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="🎉"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/btn_emoji"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:background="@drawable/bg_emoji_btn"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="+"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 输入区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp">

        <EditText
            android:id="@+id/et_chat"
            style="@style/GomokuTextInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_chat"
            android:inputType="text"
            android:maxLength="60"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/btn_send"
            style="@style/GomokuButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/btn_send" />
    </LinearLayout>
</LinearLayout>
